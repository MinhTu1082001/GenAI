# ============================================================================
# config.ini.example — cấu hình đầy đủ (số thật cho báo cáo cuối)
# ----------------------------------------------------------------------------
# Hai cách dùng:
#   1) Chạy thẳng, không đụng config.ini:   python run.py config.ini.example
#   2) Hoặc chép đè rồi chạy như thường:
#        CMD       : copy /Y config.ini.example config.ini
#        PowerShell: Copy-Item config.ini.example config.ini -Force
#      rồi:  python run.py
#
# CPU chạy vài giờ cho đủ 3 biến thể; có GPU NVIDIA sẽ tự dùng (device để trống).
# Trước lần chạy thật đầu tiên nên bật sanity = true MỘT lần để khám bug.
# ============================================================================

[pipeline]
# Bật/tắt từng bước (true/false). Mặc định: vòng model -> eval -> plots -> demo.
# Các bước DỮ LIỆU (download/prepare/tagger/split/synthetic) KHÔNG nằm ở đây:
# chúng nặng, cần internet, hoặc làm ĐÓNG BĂNG split — chạy tay theo huong_dan.
sanity   = false   # true = chạy train.py --overfit 50 trước (khuyến nghị 1 lần đầu)
train    = true    # train 3 biến thể tam giác ablation
evaluate = true    # chấm trên dev (test chỉ chấm MỘT LẦN ở cuối, đổi tay)
plots    = true    # sinh hình cho báo cáo
demo     = true    # ráp JSON dịch + chú giải ngữ pháp cho 1 câu

[train]
# Tam giác ablation — GIỮ nguyên 3 biến thể mới so sánh được
variants = seq2seq, cvae1, cvae2

# --- Dữ liệu & vòng lặp ---
limit      = 0      # 0 = toàn bộ train
epochs     = 60     # đúng mặc định thiết kế (train.py CFG); early stopping sẽ tự dừng sớm
dev_eval_n = 200    # số câu dev greedy-decode mỗi epoch (mặc định thiết kế)

# --- Siêu tham số mô hình/loss: để mặc định = đúng thiết kế huong_dan ---
batch       = 64
lr          = 0.001
seed        = 13
lam         = 1.0    # trọng số CE ngữ pháp
free_bits   = 0.2    # nats/chiều
p_wd        = 0.3    # word dropout decoder dịch
beta_max    = 1.0
warmup_frac = 0.15
patience    = 10

# Xóa artifacts/ TRƯỚC run đầu để vocab build lại (kỷ luật mục 1: vocab chung).
# 2 run sau tự tái dùng vocab. Đừng đổi limit giữa chừng khi để true.
fresh_artifacts = true
device =            # trống = auto (cpu/cuda); ghi 'cpu' để ép CPU

[sanity]
# Chỉ dùng khi pipeline.sanity = true
n      = 50
epochs = 300

[evaluate]
split  = dev        # 'dev' khi tune; 'test' CHỈ ở cuối, chấm một lần
iwae_k = 64

[demo]
run      = cvae2    # biến thể đem demo (nên là cvae2 — đủ decoder ngữ pháp)
sentence = 昨日買ったばかりのパソコンが壊れてしまいました。
